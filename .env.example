# ============================================================
# Chinghis Scan — Environment Variables Template
# Copy this to .env and fill in real values. NEVER commit .env
# ============================================================

# --- GCP ---
GOOGLE_APPLICATION_CREDENTIALS=./infra/gcp-key.json
GCP_PROJECT_ID=chinghis-scan
GCP_REGION=us-central1

# --- Database ---
DATABASE_URL=postgresql://chinghis_user:YOUR_PASSWORD@/chinghis?host=/cloudsql/chinghis-scan:us-central1:chinghis-db
DATABASE_URL_LOCAL=postgresql://chinghis_user:YOUR_PASSWORD@localhost:5432/chinghis

# --- Cloud Storage ---
GCS_BUCKET=cs2-chinghis-scan

# --- Cloud Tasks ---
CLOUD_TASKS_QUEUE=chinghis-scan-queue
CLOUD_TASKS_LOCATION=us-central1

# --- Gemini / Vertex AI ---
GEMINI_MODEL_ORCHESTRATOR=gemini-2.5-pro
GEMINI_MODEL_ANALYST=gemini-2.5-flash
GEMINI_MODEL_GENERATOR=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- LangSmith ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=chinghis-scan

# --- FACEIT ---
FACEIT_API_KEY=your_faceit_api_key
FACEIT_CLIENT_ID=your_faceit_client_id
FACEIT_CLIENT_SECRET=your_faceit_client_secret
FACEIT_WEBHOOK_SECRET=your_webhook_secret

# --- Apify (HLTV scraper) ---
APIFY_API_TOKEN=your_apify_token
APIFY_HLTV_ACTOR_ID=your_hltv_actor_id

# --- Hetzner (Practice Servers) ---
HETZNER_API_TOKEN=your_hetzner_api_token
HETZNER_SERVER_TYPE=cx21
HETZNER_LOCATION=nbg1

# --- App ---
APP_ENV=development
API_SECRET_KEY=generate_a_strong_random_key_here
